{
  "@context": "https://etzhayyim.com/ns/actor/v1",
  "@id": "did:web:hs.etzhayyim.com",
  "actors": [
    {
      "description": "Canonical HS section, chapter, heading, and subheading hierarchy registry.",
      "displayName": "Taxonomy",
      "path": "taxonomy:canonical"
    },
    {
      "description": "GTIN, CPC, ISIC, and catalog concordance resolution for traded goods.",
      "displayName": "Concordance",
      "path": "concordance:trade-item"
    },
    {
      "description": "Trade evidence coverage across imports, exports, routes, and declared product mix.",
      "displayName": "Trade Flow",
      "path": "analytics:trade-flow"
    },
    {
      "description": "Tariff, restriction, sanctions, and licensing overlays for border control workflows.",
      "displayName": "Border Controls",
      "path": "compliance:border-controls"
    }
  ],
  "capabilities": [
    "graph.query",
    "graph.write",
    "agent.chat",
    "agent.invoke",
    "derive:social"
  ],
  "complianceDocs": [
    "90-docs/rules/compliance/per-did-kyumei-shinka-autonomy.md",
    "90-docs/260415-hs-code-domain-coverage-design.md"
  ],
  "convoSystemPrompt": "You are the HS trade-classification coordinator. Manage the Harmonized System hierarchy, explain section/chapter/heading/subheading distinctions, resolve GTIN and industrial concordances, and surface country-specific border-control overlays without mixing canonical taxonomy with jurisdiction-specific policy.",
  "description": "Global Harmonized System classification coordinator for trade goods, customs classification, taxonomy concordance, and jurisdiction overlays.",
  "displayName": "HS Trade Classification Coordinator",
  "domainKnowledgeRequired": true,
  "runtime": "k8s-langserver",
  "edge": "sveltekit-proxy",
  "legacyExecutionTier": "T1",
  "governance": {
    "classification": "internal",
    "raci": "responsible"
  },
  "heartbeatRequired": true,
  "name": "hs",
  "nanoid": "hs6c0d3x",
  "performerType": "service",
  "pipelines": [
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (n) WHERE n.repo = $did RETURN count(n) AS nodeCount, coalesce(max(n._seq), 0) AS latestSeq LIMIT 1"
          },
          "fn": "graph.query",
          "id": "coverageNodes"
        },
        {
          "args": {
            "sql": "MATCH (n) WHERE n.repo = $did AND n.collection IS NOT NULL RETURN n.collection AS collection, count(n) AS cnt ORDER BY cnt DESC LIMIT 10"
          },
          "fn": "graph.query",
          "id": "coverageCollections"
        },
        {
          "args": {
            "message": "HS coverage report. Nodes: $coverageNodes.rows. Collections: $coverageCollections.rows. Summarize taxonomy coverage, concordance gaps, trade evidence gaps, and policy overlay gaps. Recommend the weakest chapter or heading to expand next."
          },
          "depends_on": [
            "coverageNodes",
            "coverageCollections"
          ],
          "fn": "agent.chat",
          "id": "analyzeCoverage"
        },
        {
          "args": {
            "template": "HS coverage report: $analyzeCoverage.text"
          },
          "fn": "derive:social",
          "id": "announce"
        }
      ],
      "trigger": {
        "cron": "0 */6 * * *",
        "type": "cron"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (n:HsNode {code: $input.code}) RETURN n.code AS code, n.level AS level, n.name AS name, n.parent_code AS parentCode, n.repo, n.collection LIMIT 1"
          },
          "fn": "graph.query",
          "id": "node"
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.hs.getNode",
        "type": "xrpc"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (n:HsNode {parent_code: $input.code}) RETURN n.code AS code, n.level AS level, n.name AS name ORDER BY n.code LIMIT 200"
          },
          "fn": "graph.query",
          "id": "children"
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.hs.getChildren",
        "type": "xrpc"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (c:HsConcordance) WHERE c.source_system = $input.sourceSystem AND c.source_code = $input.sourceCode RETURN c.hs_code AS hsCode, c.confidence AS confidence, c.basis AS basis ORDER BY c.confidence DESC LIMIT 20"
          },
          "fn": "graph.query",
          "id": "matches"
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.hs.resolveConcordance",
        "type": "xrpc"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (p:HsPolicyOverlay {country_code: $input.countryCode, hs_code: $input.code}) RETURN p.country_code AS countryCode, p.hs_code AS code, p.tariff_rate AS tariffRate, p.restriction_summary AS restrictionSummary, p.license_required AS licenseRequired LIMIT 20"
          },
          "fn": "graph.query",
          "id": "policy"
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.hs.getPolicyOverlay",
        "type": "xrpc"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (n) WHERE n.repo = $did RETURN count(n) AS nodes LIMIT 1"
          },
          "fn": "graph.query",
          "id": "health"
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.hs.health",
        "type": "xrpc"
      }
    }
  ],
  "profile": {
    "agentType": "autonomous",
    "capabilities": [
      "describe-hs-node",
      "resolve-concordance",
      "explain-classification",
      "report-coverage",
      "summarize-policy-overlay"
    ],
    "description": "Canonical trade-classification agent for HS-based product and customs reasoning.",
    "displayName": "HS Trade Classification Coordinator",
    "isBot": true,
    "operator": "etzhayyim.co.jp"
  },
  "requiredCollections": [
    "com.etzhayyim.apps.standard.shinkaEvolution",
    "com.etzhayyim.apps.standard.shinkaKnowledge"
  ],
  "requiredLoops": [
    "shinka",
    "koji",
    "kyumei",
    "domain-knowledge"
  ],
  "standardRule": "per-did-kyumei-shinka-autonomy@2026-04-13",
  "standardStatus": "required",
  "triggers": {
    "subscribeRepos": {
      "collections": [
        "com.etzhayyim.apps.hs.node",
        "com.etzhayyim.apps.hs.concordance",
        "com.etzhayyim.apps.hs.tradeEvidence",
        "com.etzhayyim.apps.hs.policyOverlay"
      ]
    }
  },
  "uiType": "yoro"
}
